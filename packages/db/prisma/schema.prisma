model Artwork {
  id          String   @id @default(cuid())
  campaignId  String   @unique
  status      String   @default("UPLOADED") // UPLOADED, UNDER_REVIEW, APPROVED, REJECTED
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  prompt      String?  // if generated via xAI
  versions    Json?    // history of versions
  finalPdf    String?
  notes       String?  // ops review notes
  uploadedAt  DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([status])
  @@index([campaignId])
}
