{
  "name": "postcard-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx turbo run dev",
    "dev:web:clean": "npm run dev:clean -w web",
    "build": "npx turbo run build",
    "db:generate": "npx turbo run db:generate",
    "db:push": "npx turbo run db:push",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma",
    "db:migrate:remote": "bash scripts/db-migrate-remote.sh",
    "db:env:sync": "node scripts/sync-db-env.mjs",
    "db:migrate:baseline": "bash scripts/baseline-prisma-migrations.sh",
    "supabase": "supabase",
    "supabase:link": "supabase link --project-ref onrvdowfqexfchjhysbm",
    "db:seed:demo": "supabase db query --linked -f scripts/seed-lupylloyd-demo.sql"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "ai": "^6.0.191"
  }
}
