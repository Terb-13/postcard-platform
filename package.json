{
  "name": "postcard-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx turbo run dev",
    "dev:web:clean": "npm run dev:clean -w web",
    "build": "npx turbo run build",
    "db:generate": "npx turbo run db:generate",
    "db:push": "npx turbo run db:push",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "ai": "^6.0.191"
  }
}
