{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env.local",
    "apps/web/postcss.config.mjs",
    "apps/web/tailwind.config.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!**/.next/cache/**"],
      "env": [
        "POSTGRES_URL", "POSTGRES_PRISMA_URL", "POSTGRES_URL_NON_POOLING", "POSTGRES_USER", "POSTGRES_HOST", "POSTGRES_PASSWORD", "POSTGRES_DATABASE",
        "SUPABASE_ANON_KEY", "SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY", "SUPABASE_JWT_SECRET", "SUPABASE_PUBLISHABLE_KEY", "SUPABASE_SECRET_KEY",
        "CLERK_WEBHOOK_SECRET", "SKIP_ENV_VALIDATION", "RESEND_API_KEY", "CLERK_SECRET_KEY", "CENSUS_API_KEY", "MAPBOX_ACCESS_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
