# Database
DATABASE_URL="postgresql://user:password@localhost:5432/postcard"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Postcard Platform <notifications@yourdomain.com>"

# File Uploads
UPLOADTHING_TOKEN=...

# Object Storage (Cloudflare R2)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=your-bucket
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Background Jobs
INNGEST_SIGNING_KEY=...

# AI (xAI)
XAI_API_KEY=xai-...

# Geo-targeting (Census ACS + Mapbox)
# Free key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# Mapbox: https://account.mapbox.com/ — use same token for server geocoding + client map
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...
MAPBOX_ACCESS_TOKEN=pk.eyJ...

# Pricing (optional — default 12 cents per piece before size multiplier)
POSTCARD_BASE_RATE_CENTS=12

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SKIP_ENV_VALIDATION=
